    CONTROL         "",IDC_HOTKEY,"msctls_hotkey32",WS_BORDER | WS_TABSTOP,58,40,112,11
    LTEXT           "按下热键打开麦克风，松开热键关闭麦克风。",IDC_STATIC,19,65,153,25
END

IDD_PROPPAGE_PTM DIALOGEX 0, 0, 195, 120
STYLE DS_SETFONT | DS_FIXEDSYS | DS_CENTER | WS_CHILD | WS_CAPTION
CAPTION "PTM"
FONT 9, "MS Shell Dlg", 400, 0, 0x0
