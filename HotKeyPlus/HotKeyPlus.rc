    LTEXT           "使用热键把麦克风切换到相反的状态。",IDC_STATIC,19,65,153,25
END

IDD_PROPPAGE_ON_OFF DIALOGEX 0, 0, 195, 120
STYLE DS_SETFONT | DS_FIXEDSYS | DS_CENTER | WS_CHILD | WS_CAPTION
